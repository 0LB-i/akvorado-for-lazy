# Copie para .env e ajuste os valores.
# O script scripts/bootstrap.sh e o scripts/install.sh geram o .env
# automaticamente perguntando usuário/senha, então normalmente você
# não precisa editar isso à mão.

# Credenciais únicas usadas em todos os serviços que pedem autenticação
# (ClickHouse e Redis)
CLICKHOUSE_DB=akvorado
CLICKHOUSE_USER=akvorado
CLICKHOUSE_PASSWORD=akvorado123
REDIS_PASSWORD=akvorado123

# Portas expostas no host (mude apenas se houver conflito)
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
REDIS_PORT=6379
ZOOKEEPER_PORT=2181
KAFKA_PORT=9092
KAFKA_EXTERNAL_PORT=9093
ORCHESTRATOR_HTTP_PORT=8080
ORCHESTRATOR_GRPC_PORT=8081
CONSOLE_HTTP_PORT=8000

# Opcional: license key gratuita da MaxMind (https://www.maxmind.com/en/geolite2/signup)
# para o scripts/install.sh baixar os bancos GeoIP automaticamente.
# Se deixar em branco, o install.sh pergunta na hora.
MAXMIND_LICENSE_KEY=
